# PostgreSQL
POSTGRES_PRIMARY_URL=postgresql+asyncpg://twitter:twitter@postgres_primary:5432/twitter
POSTGRES_REPLICA1_URL=postgresql+asyncpg://twitter:twitter@postgres_replica1:5432/twitter
POSTGRES_REPLICA2_URL=postgresql+asyncpg://twitter:twitter@postgres_replica2:5432/twitter

# Redis (main — timelines, sessions, rate limiting)
REDIS_URL=redis://redis:6379/0

# Redis Celebrity (SEPARATE dedicated instance — celebrity tweet store ONLY)
CELEBRITY_REDIS_URL=redis://redis_celebrity:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Auth
JWT_SECRET_KEY=change_this_to_a_long_random_secret_key_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
LOG_LEVEL=INFO
CELEBRITY_THRESHOLD=10000

# Rate limiting
RATE_LIMIT_PER_MINUTE=100

# Service
SERVICE_NAME=user
INSTANCE_ID=1
